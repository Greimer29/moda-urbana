# Test environment — loaded when NODE_ENV=test (see start/env.ts).
# Tests NEVER use DB_DATABASE=moda_urbana (dev). See docs/LOCAL_DEV.md.

TZ=UTC
PORT=3334
HOST=0.0.0.0
NODE_ENV=test
LOG_LEVEL=warn

APP_KEY=test-app-key-must-be-at-least-32-characters-long
APP_URL=http://localhost:3334

SESSION_DRIVER=memory

DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=moda_urbana
DB_PASSWORD=moda_urbana
DB_DATABASE=moda_urbana_test

FRONTEND_URL=http://localhost:5174

ADMIN_EMAIL=admin@test.modaurbana.local
ADMIN_PASSWORD=test-password
ADMIN_NOMBRE=Admin Test

DRIVE_DISK=local
STORAGE_LOCAL_PATH=./storage/uploads-test
