{
  "name": "desktop",
  "version": "1.0.0",
  "description": "App de escritorio Moda Urbana (Electron)",
  "author": "Moda Urbana",
  "main": "dist/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.json",
    "dev": "pnpm build:main && electron .",
    "dist": "pnpm build:main && electron-builder --win --config electron-builder.yml",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "serve-handler": "^6.1.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3"
  }
}
