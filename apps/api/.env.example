# Node
TZ=UTC
PORT=3334
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# App (generate APP_KEY with: node ace generate:key)
APP_KEY=
APP_URL=http://localhost:3334

# Session
SESSION_DRIVER=cookie

# MySQL (docker compose usa puerto 3307 en el host)
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=moda_urbana
DB_PASSWORD=moda_urbana
DB_DATABASE=moda_urbana

# Tests use a separate database — see apps/api/.env.test (NODE_ENV=test)

# CORS — origen del frontend web (Vite dev)
FRONTEND_URL=http://localhost:5174
# CORS — origen de la app de escritorio Electron (servidor local embebido)
DESKTOP_APP_ORIGIN=http://127.0.0.1:51740

# Admin user (database/seeders/admin_user_seeder.ts)
ADMIN_EMAIL=admin@modaurbana.local
ADMIN_PASSWORD=change-me-in-production
ADMIN_NOMBRE=Administrador Moda Urbana

# Storage (local disk)
DRIVE_DISK=local
STORAGE_LOCAL_PATH=./storage/uploads
